# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=SAKmart
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173,http://localhost:4173,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006,http://localhost:3007,http://localhost:3008,http://localhost:8000,http://localhost:8001,http://localhost:8002,http://localhost:8003,http://localhost:8004,http://localhost:8005,http://localhost:8006,http://localhost:8007,http://localhost:8008,http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:8083,http://localhost:8084,http://localhost:8085,http://localhost:8086,http://localhost:8087,http://localhost:8088"]

# ── Security ─────────────────────────────────────────────────────────────────
# Change SECRET_KEY to a long random string in staging/production
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database ─────────────────────────────────────────────────────────────────
# Local PostgreSQL (development)
#DATABASE_URL=postgresql://saksoft:saksoft1234@localhost:5432/clipmart

# Azure PostgreSQL (staging/production) — swap DATABASE_URL to use this
DATABASE_URL=postgresql://clipmart:saksoft$1234@saksoft-pg.postgres.database.azure.com:5432/clipmart

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=azure

# Local storage
LOCAL_UPLOAD_DIR=./uploads
LOCAL_BASE_URL=http://localhost:8000/uploads

# Azure Blob Storage (leave blank when using local)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=saksoftstorage;AccountKey=MrpGSB11Tu7dXIJfaKdIZTFoPeQzs4OhDVKLyCFLqwiEZ57ulX6PKTzkoEu5xSd0UfVy5n4Z3xnr+ASth1XDcA==;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=clipmart
AZURE_CDN_BASE_URL=

# ── Pagination ───────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=12
MAX_PAGE_SIZE=100

# ── AI / Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=AQ.Ab8RN6K7VIw4MFLpRx_w9FGEjI605OWRxMPC5KXiDuPBv7aaKA
GEMINI_MODEL=gemini-2.5-flash

# ── Email / SMTP ─────────────────────────────────────────────────────────────
